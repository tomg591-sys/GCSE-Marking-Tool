{
  "outputDirectory": "public",
  "functions": {
    "api/claude.js":  { "memory": 256, "maxDuration": 30 },
    "api/gemini.js":  { "memory": 256, "maxDuration": 30 },
    "api/ping.js":    { "memory": 128, "maxDuration": 5  }
  },
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/api/gemini", "dest": "/api/gemini.js" },
    { "src": "/api/ping",   "dest": "/api/ping.js"   },
    { "src": "/(.*)",       "dest": "/index.html"     }
  ]
}
